# ============================================================
# StockNova .gitignore
# 原则：源码与文档进库；数据/密钥/构建产物/依赖/参考库不进库
# ============================================================

# ---------- 操作系统 ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- 编辑器 / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- 日志（全部）----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
# 虚拟环境
.venv/
venv/
env/

# ---------- Node / 前端 ----------
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local

# ---------- 环境变量 / 密钥（绝不入库）----------
.env
.env.*
!.env.example
*.key
*.pem
secrets.json

# ---------- 数据库与行情数据（体积大 / 含用户配置，绝不入库）----------
*.duckdb
*.duckdb.wal
*.db
*.sqlite
*.sqlite3
backend/data/
data/

# ---------- 桌面端 / 打包产物 ----------
*.spec
*.exe
*.msi
StockNova-*.zip
release/
desktop/build/
desktop/dist/

# ---------- 参考资料（克隆的他人仓库，仅本地参考，不分发）----------
.refs/

# ---------- 其它临时 ----------
*.tmp
*.bak
prune.txt

# ---------- 开发期草稿截图（正式截图另存 docs/assets）----------
.shots/
